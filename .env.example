# ─── 数据库 ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/seekname_db?schema=public"

# ─── DeepSeek AI ─────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key

# ─── GitHub OAuth 登录 ───────────────────────────────────────────────────
# 1. 去 https://github.com/settings/developers 创建 OAuth App
# 2. Homepage URL:       http://localhost:3000
# 3. Authorization callback URL: http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/github/callback

# 登录页 GitHub 按钮可见性检测（仅填写 CLIENT_ID 即可显示按钮）
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id

# ─── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET=请在生产环境替换为随机字符串

# ─── 站点 URL ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Vercel Blob（图片上传，生产环境） ──────────────────────────────
# 在 Vercel 项目设置 → Storage → Create Blob Store 后获取
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx
