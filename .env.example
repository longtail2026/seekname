# ─── 数据库 ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/seekname_db?schema=public"

# ─── DeepSeek AI ─────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key

# ─── GitHub OAuth 登录 ───────────────────────────────────────────────────
# 1. 去 https://github.com/settings/developers 创建 OAuth App
# 2. Homepage URL:       http://localhost:3000
# 3. Authorization callback URL: http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/github/callback

# 登录页 GitHub 按钮可见性检测（仅填写 CLIENT_ID 即可显示按钮）
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id

# ─── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET=请在生产环境替换为随机字符串

# ─── 站点 URL ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── PayPal 支付 ──────────────────────────────────────────────────────
# 1. 去 https://developer.paypal.com 创建 App（沙盒模式）
# 2. Sandbox → My Apps → Create App → 选择 "Merchant"
# 3. 复制 Client ID，Sandbox 用于测试，Live 用于生产
#    沙盒测试卡：https://developer.paypal.com/tools/sandbox/
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
# 设置为 "live" 后切换到真实支付（生产环境）
PAYPAL_MODE=sandbox
# 前端 PayPal SDK 使用（与上面 CLIENT_ID 相同）
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id

# ─── 微信支付 ──────────────────────────────────────────────────────────
# 1. 去 https://pay.weixin.qq.com 申请微信支付商户号
# 2. 获取 AppID（应用ID）、MCH_ID（商户号）、API_KEY（API密钥）
# 3. 配置支付回调地址（notify_url）
WXPAY_APP_ID=your_wxpay_app_id
WXPAY_MCH_ID=your_wxpay_mch_id
WXPAY_API_KEY=your_wxpay_api_key
# 微信支付回调地址（必须是 HTTPS）
WXPAY_NOTIFY_URL=https://www.seekname.cn/api/wxpay/notify

# ─── 支付宝当面付 ──────────────────────────────────────────────────────
# 1. 去 https://open.alipay.com 创建应用并开通"当面付"产品
# 2. 获取 AppID、应用私钥、支付宝公钥
# 3. 配置回调地址（notify_url）
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key
# 支付宝回调地址（必须是 HTTPS）
ALIPAY_NOTIFY_URL=https://www.seekname.cn/api/alipay/notify

# ─── Stripe 支付 ────────────────────────────────────────────────────────
# Stripe 用于海外用户 Visa/Mastercard 支付
STRIPE_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# ─── 邮件服务 ──────────────────────────────────────────────────────────
# 用于发送邮件通知（如起名完成通知、订单确认等）
# 支持 SendGrid、Mailgun、QQ企业邮箱等
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
SMTP_FROM=寻名网 <noreply@seekname.cn>

# ─── Vercel Blob（图片上传，生产环境） ──────────────────────────────
# 在 Vercel 项目设置 → Storage → Create Blob Store 后获取
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx
