generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ClassicsBook {
  id          Int             @id @default(autoincrement())
  origId      Int?            @map("orig_id")
  name        String          @db.VarChar(100)
  author      String?         @db.VarChar(100)
  category    String?         @db.VarChar(20)
  dynasty     String?         @db.VarChar(20)
  description String?
  entries     ClassicsEntry[]

  @@map("classics_books")
}

model ClassicsEntry {
  id          Int           @id @default(autoincrement())
  bookId      Int?          @map("book_id")
  bookName    String?       @map("book_name") @db.VarChar(100)
  chapterName String?       @map("chapter_name") @db.VarChar(200)
  ancientText String        @map("ancient_text")
  modernText  String?       @map("modern_text")
  keywords    String[]
  book        ClassicsBook? @relation(fields: [bookId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([bookId], map: "idx_ce_book")
  @@index([keywords], map: "idx_ce_keywords", type: Gin)
  @@map("classics_entries")
}

model NameSample {
  id        Int     @id @default(autoincrement())
  fullName  String  @map("full_name") @db.VarChar(30)
  surname   String? @db.VarChar(10)
  givenName String? @map("given_name") @db.VarChar(20)
  gender    String? @db.Char(1)
  frequency Int?
  pinyin    String? @db.VarChar(100)

  @@index([surname], map: "idx_ns_surname")
  @@index([gender], map: "idx_ns_gender")
  @@map("name_samples")
}

model KangxiDict {
  id          Int       @id @default(autoincrement())
  character   String    @db.VarChar(10)
  pinyin      String?   @db.VarChar(50)
  radical     String?   @db.VarChar(10)
  strokeCount Int?      @map("stroke_count")
  meaning     String?
  wuxing      String?   @db.VarChar(10)
  source      String?   @db.VarChar(100)
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([character], map: "idx_kd_char")
  @@index([pinyin], map: "idx_kd_pinyin")
  @@index([wuxing], map: "idx_kd_wuxing")
  @@map("kangxi_dict")
}

model SensitiveWord {
  id         Int       @id @default(autoincrement())
  word       String
  category   String?   @db.VarChar(50)
  level      Int?
  sourceFile String?   @map("source_file") @db.VarChar(100)
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([word], map: "idx_sw_word")
  @@index([category], map: "idx_sw_category")
  @@map("sensitive_words")
}

model WuxingCharacter {
  id          Int       @id @default(autoincrement())
  character   String    @db.VarChar(10)
  wuxing      String?   @db.VarChar(10)
  meaning     String?
  suitability String?
  pinyin      String?   @db.VarChar(50)
  strokeCount Int?      @map("stroke_count")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([character], map: "idx_wx_char")
  @@index([wuxing], map: "idx_wx_wuxing")
  @@map("wuxing_characters")
}

// ─────────────────────────────────────────────
// 7. 用户表
// ─────────────────────────────────────────────
model User {
  id          String   @id @default(cuid())
  email       String?  @unique
  phone       String?  @unique
  name        String?  @db.VarChar(50)
  
  // 微信相关
  wxOpenId    String?  @unique @map("wx_openid")
  wxUnionId   String?  @map("wx_unionid")
  
  // 状态
  status      String   @default("active") @db.VarChar(20)
  
  // VIP信息
  vipLevel    Int      @default(0) @map("vip_level")
  vipExpire   DateTime? @map("vip_expire")
  
  // 积分余额
  points      Int      @default(0)
  balance     Decimal  @default(0) @db.Decimal(10, 2)
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  // 关联
  orders      Order[]
  nameRecords NameRecord[]

  @@index([wxOpenId], map: "idx_user_wx")
  @@index([status], map: "idx_user_status")
  @@map("users")
}

// ─────────────────────────────────────────────
// 8. 订单表
// ─────────────────────────────────────────────
model Order {
  id          String   @id @default(cuid())
  orderNo     String   @unique @map("order_no")
  
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  
  // 订单类型
  type        String   @db.VarChar(20)  // name/report/vip
  
  // 金额
  amount      Decimal  @db.Decimal(10, 2)
  
  // 支付状态
  payStatus   String   @default("pending") @map("pay_status") @db.VarChar(20)
  payMethod   String?  @map("pay_method") @db.VarChar(20)
  payTime     DateTime? @map("pay_time")
  
  // 订单状态
  status      String   @default("pending") @db.VarChar(20)  // pending/processing/completed/closed

  // 关联的起名记录
  nameRecordId String? @map("name_record_id")
  nameRecord   NameRecord? @relation(fields: [nameRecordId], references: [id])

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId], map: "idx_order_user")
  @@index([orderNo], map: "idx_order_no")
  @@index([payStatus], map: "idx_order_pay")
  @@index([status], map: "idx_order_status")
  @@map("orders")
}

// ─────────────────────────────────────────────
// 9. 起名记录表
// ─────────────────────────────────────────────
model NameRecord {
  id          String   @id @default(cuid())

  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])

  // 起名参数
  surname     String   @db.VarChar(10)
  gender      String   @db.Char(1)
  birthDate   DateTime @map("birth_date")
  birthTime   String?  @map("birth_time") @db.VarChar(10)

  // 八字信息
  baziYear    String?  @map("bazi_year") @db.VarChar(10)
  baziMonth   String?  @map("bazi_month") @db.VarChar(10)
  baziDay     String?  @map("bazi_day") @db.VarChar(10)
  baziHour    String?  @map("bazi_hour") @db.VarChar(10)

  // 五行喜忌
  wuxingLikes String[] @map("wuxing_likes")
  wuxingAvoids String[] @map("wuxing_avoids")

  // 期望寓意
  expectations String?
  style       String?  @db.VarChar(20)

  // 生成的名字结果
  results     Json?

  // 状态
  status      String   @default("generating") @db.VarChar(20)

  // 是否已支付查看
  isPaid      Boolean  @default(false) @map("is_paid")

  // 引用典籍
  citedBooks  String[] @map("cited_books")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // 关联
  orders      Order[]

  @@index([userId], map: "idx_nr_user")
  @@index([surname], map: "idx_nr_surname")
  @@index([status], map: "idx_nr_status")
  @@index([createdAt], map: "idx_nr_created")
  @@map("name_records")
}
