generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ClassicsBook {
  id          Int             @id @default(autoincrement())
  origId      Int?            @map("orig_id")
  name        String          @db.VarChar(100)
  author      String?         @db.VarChar(100)
  category    String?         @db.VarChar(20)
  dynasty     String?         @db.VarChar(20)
  description String?
  entries     ClassicsEntry[]

  @@map("classics_books")
}

model ClassicsEntry {
  id          Int           @id @default(autoincrement())
  bookId      Int?          @map("book_id")
  bookName    String?       @map("book_name") @db.VarChar(100)
  chapterName String?       @map("chapter_name") @db.VarChar(200)
  ancientText String        @map("ancient_text")
  modernText  String?       @map("modern_text")
  keywords    String[]
  book        ClassicsBook? @relation(fields: [bookId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([bookId], map: "idx_ce_book")
  @@index([keywords], map: "idx_ce_keywords", type: Gin)
  @@map("classics_entries")
}

model NameSample {
  id        Int     @id @default(autoincrement())
  fullName  String  @map("full_name") @db.VarChar(30)
  surname   String? @db.VarChar(10)
  givenName String? @map("given_name") @db.VarChar(20)
  gender    String? @db.Char(1)
  frequency Int?
  pinyin    String? @db.VarChar(100)

  @@index([surname], map: "idx_ns_surname")
  @@index([gender], map: "idx_ns_gender")
  @@map("name_samples")
}

model KangxiDict {
  id          Int       @id @default(autoincrement())
  character   String    @db.VarChar(10)
  pinyin      String?   @db.VarChar(50)
  radical     String?   @db.VarChar(10)
  strokeCount Int?      @map("stroke_count")
  meaning     String?
  wuxing      String?   @db.VarChar(10)
  source      String?   @db.VarChar(100)
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([character], map: "idx_kd_char")
  @@index([pinyin], map: "idx_kd_pinyin")
  @@index([wuxing], map: "idx_kd_wuxing")
  @@map("kangxi_dict")
}

model SensitiveWord {
  id         Int       @id @default(autoincrement())
  word       String
  category   String?   @db.VarChar(50)
  level      Int?
  sourceFile String?   @map("source_file") @db.VarChar(100)
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([word], map: "idx_sw_word")
  @@index([category], map: "idx_sw_category")
  @@map("sensitive_words")
}

model WuxingCharacter {
  id          Int       @id @default(autoincrement())
  character   String    @db.VarChar(10)
  wuxing      String?   @db.VarChar(10)
  meaning     String?
  suitability String?
  pinyin      String?   @db.VarChar(50)
  strokeCount Int?      @map("stroke_count")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([character], map: "idx_wx_char")
  @@index([wuxing], map: "idx_wx_wuxing")
  @@map("wuxing_characters")
}

// ─────────────────────────────────────────────
// 7. 用户表
// ─────────────────────────────────────────────
model User {
  id          String   @id @default(cuid())
  email       String?  @unique
  phone       String?  @unique
  password    String?  // bcrypt 哈希密码
  name        String?  @db.VarChar(50)
  avatar      String?  // 头像 URL（动漫风格）
  
  // 个人信息
  gender      String?  @db.VarChar(10)   // 男/女
  occupation  String?  @db.VarChar(50)   // 职业
  hobbies     String[]                  // 爱好列表
  
  // 微信相关
  wxOpenId    String?  @unique @map("wx_openid")
  wxUnionId   String?  @map("wx_unionid")
  
  // 状态
  status      String   @default("active") @db.VarChar(20)
  
  // VIP信息
  vipLevel    Int      @default(0) @map("vip_level")
  vipExpire   DateTime? @map("vip_expire")
  
  // 积分余额
  points      Int      @default(0)
  balance     Decimal  @default(0) @db.Decimal(10, 2)
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  // 关联
  orders        Order[]
  nameRecords   NameRecord[]
  blogPosts     BlogPost[]
  comments      BlogComment[]
  likes         BlogLike[]
  favorites     BlogFavorite[]
  nameFavorites NameFavorite[]

  @@index([wxOpenId], map: "idx_user_wx")
  @@index([status], map: "idx_user_status")
  @@map("users")
}

// ─────────────────────────────────────────────
// 8. 订单表
// ─────────────────────────────────────────────
model Order {
  id          String   @id @default(cuid())
  orderNo     String   @unique @map("order_no") @db.VarChar(50)

  userId      String?  @map("user_id")
  user        User?    @relation(fields: [userId], references: [id])

  // 订单类型
  type        String   @db.VarChar(20)  // name/report/vip

  // 金额
  amount      Decimal  @db.Decimal(10, 2) @default(0)

  // 支付状态
  payStatus   String   @default("pending") @map("pay_status") @db.VarChar(20)
  payMethod   String?  @map("pay_method") @db.VarChar(20)
  payTime     DateTime? @map("pay_time")

  // 订单状态
  status      String   @default("pending") @db.VarChar(20)  // pending/processing/completed/closed

  // 关联的起名记录
  nameRecordId String? @map("name_record_id")
  nameRecord   NameRecord? @relation(fields: [nameRecordId], references: [id])

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId], map: "idx_order_user")
  @@index([orderNo], map: "idx_order_no")
  @@index([payStatus], map: "idx_order_pay")
  @@index([status], map: "idx_order_status")
  @@map("orders")
}

// ─────────────────────────────────────────────
// 9. 起名记录表
// ─────────────────────────────────────────────
model NameRecord {
  id          String   @id @default(cuid())

  userId      String?  @map("user_id")
  user        User?    @relation(fields: [userId], references: [id])

  // 起名参数
  surname     String   @db.VarChar(20)
  gender      String   @db.Char(1)
  birthDate   DateTime @map("birth_date")
  birthTime   String?  @map("birth_time") @db.VarChar(20)

  // 八字信息
  baziYear    String?  @map("bazi_year") @db.VarChar(20)
  baziMonth   String?  @map("bazi_month") @db.VarChar(20)
  baziDay     String?  @map("bazi_day") @db.VarChar(20)
  baziHour    String?  @map("bazi_hour") @db.VarChar(20)

  // 期望寓意
  expectations String? @db.VarChar(1000)
  style       String?  @db.VarChar(20)

  // 生成的名字结果（JSON，存名字列表+来源+评分）
  results     Json?

  // 状态
  status      String   @default("generating") @db.VarChar(20)

  // 是否已支付查看
  isPaid      Boolean  @default(false) @map("is_paid")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // 关联
  orders      Order[]

  @@index([userId], map: "idx_nr_user")
  @@index([surname], map: "idx_nr_surname")
  @@index([status], map: "idx_nr_status")
  @@index([createdAt], map: "idx_nr_created")
  @@map("name_records")
}

// ─── 10. 博客表 ────────────────────────────────────────────────────────────────
model BlogPost {
  id            Int          @id @default(autoincrement())
  userId        String       @map("user_id")
  user          User         @relation(fields: [userId], references: [id])

  title         String       @db.VarChar(200)
  slug          String       @unique @db.VarChar(250)
  summary       String?      @db.VarChar(500)
  content       String?
  coverImage    String?      @map("cover_image") @db.VarChar(500)

  viewCount     Int          @default(0) @map("view_count")
  likeCount     Int          @default(0) @map("like_count")
  commentCount  Int          @default(0) @map("comment_count")
  favoriteCount Int          @default(0) @map("favorite_count")

  status        String       @default("draft") @db.VarChar(20)  // draft | published | archived

  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  tags          BlogPostTag[]
  comments      BlogComment[]
  favorites     BlogFavorite[]

  @@index([userId], map: "idx_bp_user")
  @@index([status], map: "idx_bp_status")
  @@index([createdAt], map: "idx_bp_created")
  @@map("blog_posts")
}

model BlogTag {
  id        Int          @id @default(autoincrement())
  name      String       @unique @db.VarChar(50)
  slug      String       @unique @db.VarChar(60)
  count     Int          @default(0)
  createdAt DateTime     @default(now()) @map("created_at")

  posts     BlogPostTag[]

  @@map("blog_tags")
}

model BlogPostTag {
  id     Int      @id @default(autoincrement())
  postId Int      @map("post_id")
  tagId  Int      @map("tag_id")
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([postId, tagId], map: "uk_bpt_post_tag")
  @@index([postId], map: "idx_bpt_post")
  @@index([tagId], map: "idx_bpt_tag")
  @@map("blog_post_tags")
}

// ─── 11. 博客评论表 ─────────────────────────────────────────────────────────
model BlogComment {
  id        Int         @id @default(autoincrement())
  postId    Int         @map("post_id")
  userId    String      @map("user_id")
  parentId  Int?        @map("parent_id")        // 父评论 null=一级
  content   String      @db.Text
  likeCount Int         @default(0) @map("like_count")

  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  post      BlogPost    @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id])
  parent    BlogComment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies   BlogComment[] @relation("CommentReplies")

  @@index([postId], map: "idx_bc_post")
  @@index([userId], map: "idx_bc_user")
  @@index([parentId], map: "idx_bc_parent")
  @@map("blog_comments")
}

// ─── 12. 博客点赞表 ─────────────────────────────────────────────────────────
model BlogLike {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  targetType String  @map("target_type") @db.VarChar(20)  // post | comment
  targetId  Int      @map("target_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, targetType, targetId], map: "uk_blog_like")
  @@index([userId], map: "idx_bl_user")
  @@map("blog_likes")
}

// ─── 13. 博客收藏表 ─────────────────────────────────────────────────────────
model BlogFavorite {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  postId    Int      @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")

  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, postId], map: "uk_blog_favorite")
  @@index([userId], map: "idx_bf_user")
  @@index([postId], map: "idx_bf_post")
  @@map("blog_favorites")
}

// ─── 14. 名字典藏表 ──────────────────────────────────────────────────────────
model NameFavorite {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])

  // 名字基本信息
  surname   String   @db.VarChar(10)
  fullName  String   @map("full_name") @db.VarChar(30)
  gender    String   @db.Char(1)       // M/F
  score     Int?     @default(0)

  // 完整分析结果（JSON，兼容 NameResult 结构）
  analysis  Json?                          @map("analysis")
  wuxing    String[] @map("wuxing")          // 喜用五行
  source    String? @db.VarChar(200)        // 来源：naming_results / api_generate
  note      String? @db.VarChar(200)        // 用户备注

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, fullName], map: "uk_name_fav_user_name")
  @@index([userId], map: "idx_nf_user")
  @@index([createdAt], map: "idx_nf_created")
  @@map("name_favorites")
}

// ─── 字符频率表（起名评分：常用度维度）───────────────────────────────
// 用 raw SQL 查询，所以这个 model 只是为了让 Prisma 引擎识别表存在
model CharacterFrequency {
  char      String @id @db.VarChar(1)
  freq      Int    @default(0) @db.Integer
  freqRank  Int    @default(9999) @map("freq_rank") @db.Integer
  genderM   Int    @default(0) @map("gender_m") @db.Integer
  genderF   Int    @default(0) @map("gender_f") @db.Integer

  @@map("character_frequency")
}
